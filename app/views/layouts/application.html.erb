<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Eventbrite" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Eventbrite">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "vendor/bootstrap.min", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container-fluid">
        <%= link_to "Accueil", root_path, class: "navbar-brand" %>
        <%= link_to "Créer un événement", new_event_path, class: "nav-link" %>
        <div class="navbar-nav ms-auto">
          <% if user_signed_in? %>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Mon profil</a>
              <ul class="dropdown-menu">
                <li><%= link_to "Mon profil", user_path(current_user), class: "dropdown-item" %></li>
                <li><%= link_to "Se déconnecter", destroy_user_session_path, data: { turbo_method: :delete }, class: "dropdown-item" %></li>
              </ul>
            </li>
          <% else %>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">S'inscrire / Se connecter</a>
              <ul class="dropdown-menu">
                <li><%= link_to "S'inscrire", new_user_registration_path, class: "dropdown-item" %></li>
                <li><%= link_to "Se connecter", new_user_session_path, class: "dropdown-item" %></li>
              </ul>
            </li>
          <% end %>
        </div>
      </div>
    </nav>
    <%= yield %>
  </body>
</html>
